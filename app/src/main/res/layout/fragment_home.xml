<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8F0">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="30dp">

            <!-- Header background -->
            <View
                android:id="@+id/headerBg"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#2E7D32"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Dekorasi blob kuning di header -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="-50dp"
                android:layout_marginEnd="-50dp"
                android:background="#F9D56E"
                android:alpha="0.15"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Dekorasi blob hijau muda di header -->
            <View
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_marginStart="-40dp"
                android:layout_marginTop="80dp"
                android:background="#8BC34A"
                android:alpha="0.2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Label kecil kuning di atas judul -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:text="SELAMAT DATANG"
                android:textColor="#F9D56E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginHorizontal="32dp"
                android:text="Dashboard\nBina Desa Digital"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:letterSpacing="0.01"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

            <!-- Card logo dengan border kuning -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginTop="-45dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="12dp"
                app:strokeColor="#F9D56E"
                app:strokeWidth="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerBg">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/logo_bina_desa" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvTitleApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="BINA DESA"
                android:textColor="#1B5E20"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogo" />

            <!-- Garis aksen kuning bawah judul -->
            <View
                android:id="@+id/dividerYellow"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:background="#F9D56E"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitleApp" />

            <!-- Card Web Bina Desa -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnWebViewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E8F5E9"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/dividerYellow">

                <LinearLayout
                    android:id="@+id/btnWebView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#2E7D32" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Web Bina Desa"
                            android:textColor="#1B5E20"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Klik untuk akses website desa"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Panah dengan background hijau -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#2E7D32"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="#FFFFFF" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips card - kuning -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/materialCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#F9D56E"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/btnWebViewCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#F9A825" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tips: Gunakan layanan digital untuk mempercepat administrasi desa kamu."
                        android:textColor="#5D4037"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="#C62828"
                app:strokeColor="#FFCDD2"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_delete"
                app:iconTint="#C62828"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/materialCardView"
                app:layout_constraintVertical_bias="0.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>